{% extends 'base.html.twig' %}

{% block body %}
    <div class="container">
        <div class="row mt-5">
            <div class="col">
                <h3>{{ client.name }}</h3>
                <p class="pull-right text-sm">
                    Creato il {{ client.createdAt|date('d/m/Y H:i:s') }}<br>
                    Aggiornato il {{ client.updatedAt|date('d/m/Y H:i:s') }}
                </p>
            </div>
        </div>
        {% if client.projects is not empty %}
            <div class="row mt-3">
                <div class="col">
                    <h4>Progetti</h4>
                    <table class="table">
                        <thead>
                        <tr>
                            <th scope="col">#</th>
                            <th scope="col">Nome</th>
                            <th scope="col">Aggiornato il</th>
                            <th scope="col"></th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for project in client.projects %}
                            {% if project.deletedAt == null %}
                                <tr>
                                    <th scope="row">{{ project.id }}</th>
                                    <td>
                                        <a href="{{ path('project_detail', {'project': project.id}) }}">{{ project.name }}</a>
                                    </td>
                                    <td>
                                        {{ project.updatedAt|date('d/m/Y') }}
                                    </td>
                                </tr>
                            {% endif %}
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}
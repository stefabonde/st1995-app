{% extends 'base.html.twig' %}

{% block body %}
    {% set currentPath = path(app.request.attributes.get('_route'),
        app.request.attributes.get('_route_params')) %}

    <div class="container">
        <div class="row mt-3">
            <div class="col">
                <h4>Record</h4>
                <table class="table">
                    <thead>
                    <tr>
                        <th>Data</th>
                        <th>Ore</th>
                        <th>Progetto</th>
                        <th>Attività</th>
                        <th></th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for item in list %}
                        <tr>
                            <td>{{ item.date|date('d/m/Y') }}</td>
                            <td>{{ item.hours }}</td>
                            <td>
                                <a href="{{ path('project_detail', {'project': item.project.id}) }}">{{ item.project.name }}</a>
                            </td>
                            <td>
                                {% if item.task is not empty %}
                                    <a href="{{ path('task_detail', {'task': item.task.id}) }}">{{ item.task.title }}</a>
                                {% endif %}
                            </td>
                            <td>
                                <a href="{{ path('app_time_edit', {'timeSpent': item.id, 'destination': currentPath}) }}"
                                   class="btn btn-warning"><i class="fas fa-edit"></i></a>
                                {#<a href="{{ path('app_time_delete', {'timeSpent': item.id, 'destination': currentPath}) }}"#}
                                   {#class="btn btn-danger"><i class="fas fa-trash"></i></a>#}
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}


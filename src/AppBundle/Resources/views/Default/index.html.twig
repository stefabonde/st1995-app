{% extends 'base.html.twig' %}

{% block body %}
    <div class="container">
        <div class="row mt-5">
            <div class="col">
                <h4>Riepilogo</h4>
                <div class="row">
                    <div class="col float-left mr-3 border text-center">
                        <div class="card-body">
                            <h5 class="card-title">Settimana</h5>
                            <p class="card-text">{{ totalWeek }} ore caricate</p>
                            <a href="{{ path('app_time_list', {'type': 'week'}) }}"
                               class="btn btn-secondary">Dettaglio</a>
                        </div>
                    </div>
                    <div class="col float-left mr-3 border text-center">
                        <div class="card-body">
                            <h5 class="card-title">Mese</h5>
                            <p class="card-text">{{ totalMonth }} ore caricate</p>
                            <a href="{{ path('app_time_list', {'type': 'month'}) }}"
                               class="btn btn-secondary">Dettaglio</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row mt-3">
            <div class="col">
                <h4>Attività</h4>
                <table class="table">
                    <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Progetto</th>
                        <th>Priorità</th>
                        <th>Aggiornato il</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for task in tasks %}
                        <tr>
                            <td><a href="{{ path('task_detail', {'task': task.id}) }}">{{ task.title }}</a></td>
                            <td>{{ task.project }}</td>
                            <td><i class="fas {{ task.priority.icon }}"></i> {{ task.priority }}</td>
                            <td>{{ task.updatedAt|date('d/m/Y') }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
                <hr>
                <a href="{{ path('task_index') }}">Vedi tutte le attività <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>
    </div>
{% endblock %}